# SmartServe Production SaaS Environment Variables
# Populate variables in your secure dashboard settings.

# 1. MongoDB Database Connection
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/smartserve?retryWrites=true&w=majority

# 2. PostgreSQL Relational Database Connection
DATABASE_URL=postgresql://<username>:<password>@localhost:5432/smartserve?sslmode=require

# 3. Security Token Encryption Secret
JWT_SECRET=your_production_secure_signing_jwt_secret_key

# 4. SMS carrier configuration (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SERVICE_SID=
TWILIO_FROM_NUMBER=

# 5. Alternate SMS carrier configuration (Fast2SMS)
FAST2SMS_API_KEY=

# 6. Payment Gateway credentials (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# 7. Google Maps Integration
GOOGLE_MAPS_PLATFORM_KEY=

# 8. Gemini Generative AI Model 
GEMINI_API_KEY=

# 9. SmartServe Railway & PNR API
TRAIN_API_KEY=
TRAIN_API_URL=https://api.railwayapi.com/v2/
